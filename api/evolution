      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx) => ctx.parsed.y != null
                ? ctx.dataset.label + ' : ' + ctx.parsed.y.toFixed(2).toLocaleString('fr-FR') + ' %'
                : 'N/A'
            }
          }
        },
        scales: {
          y: {
            ticks: { callback: (v) => v.toLocaleString('fr-FR') + ' %' },
            grid: { color: '#3B3B3B' }
