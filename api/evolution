    return `
      <tr>
        <td><strong>${annee}</strong></td>
        ${showSection ? `<td>${s ? s.prix_median.toLocaleString('fr-FR') + ' €/m²' : '-'}</td><td>${s ? s.nb_transactions + ' ventes' : '-'}</td>` : ''}
